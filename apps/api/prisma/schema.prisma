generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  manager
  mechanic
}

enum CustomerType {
  personal
  business
}

enum TimerState {
  idle
  running
  paused
  stopped
}

enum PurchaseOrderStatus {
  requested
  received
}

enum PaymentStatus {
  pending
  paid
  overdue
}

enum NotificationType {
  reception_confirmation
  budget_request
  repair_completed
  awaiting_parts_delay
}

enum StockMovementType {
  in
  out
  adjustment
}

model User {
  id            String         @id @default(cuid())
  fullName      String
  email         String         @unique
  passwordHash  String
  role          UserRole
  createdOrders ServiceOrder[]
  interventions Intervention[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Customer {
  nif           String         @id @db.Char(9)
  customerType  CustomerType
  fullName      String
  legalName     String?
  email         String
  phone         String
  address       String?
  creditLimit   Decimal?       @db.Decimal(12, 2)
  paymentTerms  String?
  isArchived    Boolean        @default(false)
  scooters      Scooter[]
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([fullName])
  @@index([email])
}

model Scooter {
  serialNumber   String         @id
  brand          String
  model          String
  conditionNotes String?
  customerNif    String         @db.Char(9)
  customer       Customer       @relation(fields: [customerNif], references: [nif])
  isArchived     Boolean        @default(false)
  serviceOrders  ServiceOrder[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([customerNif])
}

model ServiceOrder {
  id                      String   @id @default(cuid())
  serviceOrderNumber      Int      @unique @default(autoincrement())
  customerNif             String   @db.Char(9)
  scooterSerialNumber     String
  reportedProblem         String
  status                  String   @default("received")
  estimatedCompletionDate DateTime?
  completedAt             DateTime?
  deliveredAt             DateTime?
  diagnosis               Json?
  budget                  Json?
  budgetApproved          Boolean?
  budgetApprovalNote      String?
  budgetApprovedAt        DateTime?
  createdByUserId         String
  invoice                 Invoice?
  interventions           Intervention[]
  historyEntries          ServiceOrderHistoryEntry[]
  customer                Customer @relation(fields: [customerNif], references: [nif])
  scooter                 Scooter  @relation(fields: [scooterSerialNumber], references: [serialNumber])
  createdByUser           User     @relation(fields: [createdByUserId], references: [id])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([customerNif])
  @@index([scooterSerialNumber])
  @@index([status])
}

model ServiceOrderHistoryEntry {
  id             String       @id @default(cuid())
  serviceOrderId String
  action         String
  note           String?
  fromStatus     String?
  toStatus       String?
  changedByUserId String?
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
  @@index([createdAt])
}

model Intervention {
  id             String             @id @default(cuid())
  serviceOrderId String
  description    String
  mechanicUserId String
  notes          String?
  elapsedSeconds Int                @default(0)
  timerStartedAt DateTime?
  timerState     TimerState         @default(idle)
  serviceOrder   ServiceOrder       @relation(fields: [serviceOrderId], references: [id])
  mechanic       User               @relation(fields: [mechanicUserId], references: [id])
  parts          InterventionPart[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([serviceOrderId])
  @@index([mechanicUserId])
}

model Supplier {
  id            String          @id @default(cuid())
  name          String
  email         String
  phone         String
  paymentTerms  String
  parts         Part[]
  purchaseOrders PurchaseOrder[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Part {
  partReference String             @id
  description   String
  supplierId    String
  costPrice     Decimal            @db.Decimal(12, 2)
  salePrice     Decimal            @db.Decimal(12, 2)
  currentStock  Int                @default(0)
  minimumStock  Int                @default(0)
  isArchived    Boolean            @default(false)
  supplier      Supplier           @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseOrderItem[]
  interventionParts InterventionPart[]
  stockMovements StockMovement[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([supplierId])
  @@index([description])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  status      PurchaseOrderStatus @default(requested)
  deliveredAt DateTime?
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  partReference   String
  quantity        Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  part            Part          @relation(fields: [partReference], references: [partReference])

  @@index([purchaseOrderId])
  @@index([partReference])
}

model InterventionPart {
  id             String       @id @default(cuid())
  interventionId String
  partReference  String
  quantity       Int
  note           String?
  intervention   Intervention @relation(fields: [interventionId], references: [id])
  part           Part         @relation(fields: [partReference], references: [partReference])

  @@index([interventionId])
  @@index([partReference])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  Int           @unique @default(autoincrement())
  serviceOrderId String        @unique
  paymentMethod  String
  subtotal       Decimal       @db.Decimal(12, 2)
  vatAmount      Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(pending)
  paidAt         DateTime?
  note           String?
  serviceOrder   ServiceOrder  @relation(fields: [serviceOrderId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([paymentStatus])
}

model FinancialConfiguration {
  id              String   @id
  hourlyLaborRate Decimal  @db.Decimal(12, 2)
  vatRate         Decimal  @db.Decimal(5, 2)
  notificationTemplates NotificationTemplate[]
  updatedAt       DateTime @updatedAt
}

model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  recipientEmail String
  subject       String
  body          String
  deliveryStatus String          @default("queued")
  triggerSource String?
  createdAt     DateTime         @default(now())
}

model NotificationTemplate {
  id                   String                 @id @default(cuid())
  key                  String                 @unique
  subjectTemplate      String
  bodyTemplate         String
  financialConfigId    String?
  financialConfiguration FinancialConfiguration? @relation(fields: [financialConfigId], references: [id])
  updatedAt            DateTime               @updatedAt
}

model StockMovement {
  id              String            @id @default(cuid())
  partReference   String
  movementType    StockMovementType
  origin          String
  quantityDelta   Int
  balanceAfter    Int
  note            String?
  part            Part              @relation(fields: [partReference], references: [partReference])
  createdAt       DateTime          @default(now())

  @@index([partReference])
  @@index([createdAt])
}